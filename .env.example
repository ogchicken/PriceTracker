# Copy this file to .env and fill in real values.
# docs/secrets.md explains where every secret comes from, step by step.
# The FastAPI Settings class uses the PRICETRACKER_ prefix.
# Never commit .env or paste production credentials into issue reports.

# --- 1. Deployment -----------------------------------------------------------
# Local development: COMPOSE_PROFILES=dev (adds Mailpit, no Caddy).
# VPS production:    COMPOSE_PROFILES=prod (adds the Caddy reverse proxy).
COMPOSE_PROFILES=dev
# Public domain that points at the VPS, e.g. app.example.com. Caddy requests a
# Let's Encrypt certificate for it. Leave localhost for local development.
DOMAIN=localhost
# Email address Let's Encrypt uses for certificate expiry notices.
ACME_EMAIL=

# --- 2. API runtime ----------------------------------------------------------
# development locally; production on the VPS (enables strict config validation).
PRICETRACKER_ENVIRONMENT=development
# Production must use false; the deploy validator rejects debug mode.
PRICETRACKER_SERVICE_ROLE=all
PRICETRACKER_DEBUG=true
PRICETRACKER_LOG_LEVEL=INFO
# Production: ["https://$DOMAIN"] — exact origins, HTTPS only, no wildcards.
PRICETRACKER_ALLOWED_ORIGINS=["http://localhost:3000"]
# Production: https://$DOMAIN
PRICETRACKER_FRONTEND_BASE_URL=http://localhost:3000

# --- 3. Web (Next.js) --------------------------------------------------------
# Clerk keys: see docs/secrets.md#clerk. NEXT_PUBLIC_* values are baked into
# the web image at build time; scripts/deploy.sh rebuilds on every deploy.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_TEMPLATE_NAME=pricetracker-api
API_BASE_URL=http://localhost:8000

# --- 4. PostgreSQL and Redis -------------------------------------------------
# Generate a strong password: openssl rand -hex 24 (see docs/secrets.md#self-generated)
POSTGRES_DB=pricetracker
POSTGRES_USER=pricetracker
POSTGRES_PASSWORD=change-me-locally
# Host-run uv commands use these URLs; Compose overrides the host per service.
PRICETRACKER_DATABASE_URL=postgresql+asyncpg://pricetracker:change-me-locally@localhost:5432/pricetracker
PRICETRACKER_REDIS_URL=redis://localhost:6379/0
PRICETRACKER_CELERY_BROKER_URL=redis://localhost:6379/1
PRICETRACKER_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- 5. Clerk token verification (API) ---------------------------------------
# See docs/secrets.md#clerk for the dashboard walkthrough.
PRICETRACKER_CLERK_ISSUER=https://replace-me.clerk.accounts.dev
PRICETRACKER_CLERK_AUDIENCE=pricetracker-api
# Production: ["https://$DOMAIN"]
PRICETRACKER_CLERK_AUTHORIZED_PARTIES=["http://localhost:3000"]
PRICETRACKER_CLERK_JWKS_URL=https://replace-me.clerk.accounts.dev/.well-known/jwks.json
# Svix signing secret (whsec_...) from the Clerk webhook endpoint.
PRICETRACKER_CLERK_WEBHOOK_SECRET=

# --- 6. Bright Data ----------------------------------------------------------
# See docs/secrets.md#bright-data.
PRICETRACKER_BRIGHT_DATA_API_BASE_URL=https://api.brightdata.com
PRICETRACKER_BRIGHT_DATA_API_TOKEN=
PRICETRACKER_BRIGHT_DATA_AMAZON_DATASET_ID=
PRICETRACKER_BRIGHT_DATA_EBAY_DATASET_ID=
# Self-generated shared secret: openssl rand -hex 32
PRICETRACKER_BRIGHT_DATA_WEBHOOK_SECRET=
# Production: https://$DOMAIN/api/v1/webhooks/bright-data
PRICETRACKER_BRIGHT_DATA_WEBHOOK_URL=

# --- 7. Email (Resend) -------------------------------------------------------
# See docs/secrets.md#resend. Blank key = non-delivering structured logs in
# development/test; a real key is required in production.
PRICETRACKER_RESEND_API_KEY=
PRICETRACKER_EMAIL_FROM="PriceTracker <alerts@example.test>"

# --- 8. Scheduling, safety, and workload limits ------------------------------
PRICETRACKER_TRACKING_INTERVAL_HOURS=6
PRICETRACKER_TRACKING_JITTER_MINUTES=30
PRICETRACKER_PRODUCT_LEASE_MINUTES=15
PRICETRACKER_PROVIDER_JOB_STALE_MINUTES=45
PRICETRACKER_PROVIDER_MAX_ATTEMPTS=5
PRICETRACKER_ALERT_REARM_PERCENT=3
PRICETRACKER_MAX_ACTIVE_WATCHES_PER_USER=50
PRICETRACKER_WATCH_CREATE_RATE_LIMIT_PER_HOUR=20
PRICETRACKER_WEBHOOK_MAX_BYTES=5000000
WORKER_CONCURRENCY=2

# --- 9. Locally published container ports (loopback only) --------------------
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
WEB_PORT=3000
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
